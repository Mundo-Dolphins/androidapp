{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Historical Games API Contract",
  "description": "Schema for historical/seasons/{year}/games.json endpoint",
  "type": "object",
  "properties": {
    "games": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "game_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "sections": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": [
          "game_id",
          "title",
          "date",
          "slug",
          "sections"
        ],
        "additionalProperties": true
      }
    }
  },
  "required": [
    "games"
  ],
  "additionalProperties": true
}
