{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Episodes API Contract",
  "description": "Schema for season_{id}.json endpoint",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "dateAndTime": {
        "type": "string",
        "format": "date-time"
      },
      "description": {
        "type": "string"
      },
      "audio": {
        "type": "string",
        "format": "uri"
      },
      "imgMain": {
        "type": "string",
        "format": "uri"
      },
      "imgMini": {
        "type": "string",
        "format": "uri"
      },
      "len": {
        "type": "string"
      },
      "link": {
        "type": "string",
        "format": "uri"
      },
      "title": {
        "type": "string"
      }
    },
    "required": [
      "dateAndTime",
      "description",
      "audio",
      "imgMain",
      "imgMini",
      "len",
      "link",
      "title"
    ],
    "additionalProperties": true
  }
}
